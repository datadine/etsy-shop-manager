# ── Etsy API Credentials ──────────────────────────────────────────────────────
# Get these from https://www.etsy.com/developers/your-apps
ETSY_KEY=your_etsy_api_keystring_here
ETSY_SECRET=your_etsy_shared_secret_here

# ── Etsy Shop ─────────────────────────────────────────────────────────────────
SHOP_NAME=your_etsy_shop_name
SHOP_ID=your_etsy_shop_id

# ── Email (Gmail SMTP) ────────────────────────────────────────────────────────
# Use a Gmail App Password (not your real password)
# https://support.google.com/accounts/answer/185833
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password
EMAIL_FROM=your_email@gmail.com
EMAIL_TO=your_email@gmail.com,optional_second_email@gmail.com

# ── Tool URL ──────────────────────────────────────────────────────────────────
# The public URL where your tool is hosted
TOOL_URL=https://your-domain.com
